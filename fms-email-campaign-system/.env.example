# Omnisend API key (required)
OMNISEND_API_KEY=

# Anthropic API key (required for --deep audit; optional for v1)
ANTHROPIC_API_KEY=

# Shopify Admin API token (optional; only needed for Files-tab ingestion path)
SHOPIFY_ADMIN_TOKEN=

# Active brand profile (matches a file in config/<brand>.toml)
FMS_BRAND=fms

# Project state directory (default: ./.fms)
FMS_STATE_DIR=.fms
